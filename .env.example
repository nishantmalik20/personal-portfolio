# Resend — contact form delivery (https://resend.com)
# Leave empty in local dev: the form will succeed without sending email.
RESEND_API_KEY=

# Where contact form messages are delivered.
CONTACT_TO_EMAIL=

# Verified sender, e.g. "Nishant <hello@inishant.com>".
# Defaults to Resend's onboarding sender when empty.
CONTACT_FROM_EMAIL=
